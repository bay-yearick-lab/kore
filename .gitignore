# Python
__pycache__/
*.pyc
*.pyo
.venv/
.pytest_cache/

# uv-managed env: keep lock file, ignore the venv contents only
.python-version

# OS metadata
.DS_Store
Thumbs.db

# LaTeX byproducts (main.pdf and main.bbl are intentionally tracked so the
# paper/ directory is a self-contained arXiv submission)
paper/*.aux
paper/*.blg
paper/*.log
paper/*.out
paper/*.toc
paper/*.synctex.gz
paper/*.fls
paper/*.fdb_latexmk
paper/*.run.xml

# arXiv submission bundle (regenerated by make_arxiv.sh)
arxiv-submission.tar.gz

# Real-world benchmark dataset cache (Section 4.x).
# Fetched from OpenML and the UCI mirror on first run by
# code/kore/datasets.py and stored as parquet files for fast re-use.
data/

# CatBoost training artifacts (side-effect of CatBoostRegressor.fit when
# allow_writing_files is set; we disable it but the directory still
# appears on first import in some CatBoost versions).
catboost_info/
